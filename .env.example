# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://asahihuuhu.zeabur.app

# ── Payload CMS ───────────────────────────────────────────────────────────────
POSTGRES_URI=postgresql://user:pass@host:5432/dbname
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ── Email / SMTP (Lark Suite) ──────────────────────────────────────────────────
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=oa@extrastudio.tw
SMTP_PASS=your-lark-smtp-password
SMTP_FROM=oa@extrastudio.tw
SMTP_FROM_NAME=朝日夫婦
# Optional: where to send admin notifications
ADMIN_NOTIFY_EMAIL=oa@extrastudio.tw

# ── ECPay 金流 ────────────────────────────────────────────────────────────────
ECPAY_IS_TEST=false
ECPAY_MERCHANT_ID=your-merchant-id
ECPAY_HASH_KEY=your-hash-key
ECPAY_HASH_IV=your-hash-iv

# ── ECPay 物流（黑貓宅急便）────────────────────────────────────────────────────
# 若物流金鑰與金流不同，請分開設定；否則會自動 fallback 至 ECPAY_HASH_KEY/IV
# ECPAY_LOGISTICS_HASH_KEY=your-logistics-hash-key
# ECPAY_LOGISTICS_HASH_IV=your-logistics-hash-iv
