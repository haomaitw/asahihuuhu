# ── 必填 ──────────────────────────────────────────────────────
# 產生方法: openssl rand -base64 32
PAYLOAD_SECRET=REPLACE_WITH_STRONG_SECRET

# Zeabur 內建 PostgreSQL 會自動注入此變數，無需手動設定
# 格式: postgresql://user:pass@host:5432/dbname
POSTGRES_URI=postgresql://user:pass@host:5432/asahihuuhu

# 網站公開 URL (含協定，結尾不加斜線)
NEXT_PUBLIC_SITE_URL=https://asahihuuhu.zeabur.app

# ── ECPay 綠界金流 ─────────────────────────────────────────────
ECPAY_IS_TEST=false
ECPAY_MERCHANT_ID=YOUR_MERCHANT_ID
ECPAY_HASH_KEY=YOUR_HASH_KEY
ECPAY_HASH_IV=YOUR_HASH_IV
